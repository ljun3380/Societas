<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>

    <link
        href="/webjars/bootstrap/4.5.2/css/bootstrap.min.css"
        rel="stylesheet"
    >
    <script defer src="/webjars/jquery/3.5.1/jquery.min.js"></script>
    <script defer src="/webjars/popper.js/2.9.2/umd/popper.min.js"></script>
    <script defer src="/webjars/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <style>
        .card-img-top {
            width: 100%;
            height: 500px;
            object-fit: cover;
        }
    </style>
</head>
<body>
    <h1>Welcome to the Home Page</h1>
    <img th:src="@{/images/Sputnik 1.jpg}" alt="Sputnik 1" width="100%">
